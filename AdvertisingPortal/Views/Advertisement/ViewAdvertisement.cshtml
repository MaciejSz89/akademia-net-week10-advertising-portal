@using AdvertisingPortal.Core.Models.Domains;
@model Advertisement

@{
    ViewData["Title"] = Model.Title;
}


<div id="carouselIndicators" class="carousel slide" data-bs-ride="carousel">
  <div class="carousel-indicators">
    @foreach (var picture in Model.Pictures)
    {
        <div class="carousel-item active">
            <img class="d-block w-100"
             src="data:image;base64,@System.Convert.ToBase64String(picture.Image)" />
        </div>
    }
    <button type="button" data-bs-target="#carouselIndicators" data-bs-slide-to="0" class="active" aria-current="true"></button>

    @for (int i = 0; i < Model.Pictures.Where(x => !x.IsMainPicture).Count(); i++)
    {
        <button type="button" data-bs-target="#carouselIndicators" data-bs-slide-to="@(i + 1)"></button>
    }

  </div>
  <div class="carousel-inner">
        <div class="carousel-item active">
            <img class="d-block w-100"
                 src="data:image;base64,@System.Convert.ToBase64String(Model.Pictures.First(x => x.IsMainPicture).Image)" />
        </div>
        @foreach (var picture in Model.Pictures.Where(x => !x.IsMainPicture))
        {
            <div class="carousel-item active">
                <img class="d-block w-100"
                 src="data:image;base64,@System.Convert.ToBase64String(picture.Image)" />
            </div>
        }
  </div>
  <button class="carousel-control-prev" type="button" data-bs-target="#carouselIndicators" data-bs-slide="prev">
    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Previous</span>
  </button>
  <button class="carousel-control-next" type="button" data-bs-target="#carouselIndicators" data-bs-slide="next">
    <span class="carousel-control-next-icon" aria-hidden="true"></span>
    <span class="visually-hidden">Next</span>
  </button>
</div>


