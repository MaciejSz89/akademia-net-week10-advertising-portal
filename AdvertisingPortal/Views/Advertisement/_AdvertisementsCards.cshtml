@using AdvertisingPortal.Core.Models.Domains;

@model IEnumerable<Advertisement>


<div class="d-flex justify-content-evenly flex-wrap">
    @foreach (var advertisement in Model)
    {
        <div class="card mb-3" style="width: 18rem;">
            <div class="backgroundEffect">
              @if (advertisement.Pictures != null && advertisement.Pictures.Any())
              {
                <img src="data:image;base64,@System.Convert.ToBase64String(advertisement.Pictures.Single(x=>x.IsMainPicture).Image)" class="card-img-top" alt="...">
              }
              <div class="card-body d-flex flex-column">
                <h5 class="card-title">@advertisement.Title</h5>
                             
                <div class="align-self-end"><strong>@advertisement.Price.ToString("0.00") zł</strong></div>
                <div class="table-nickname-caption align-self-end">Dodane przez: @advertisement.User?.Nickname</div>
                <div class="table-nickname-caption align-self-end">@advertisement.Location - @advertisement.DateOfPublication.ToString("f")</div>   
              </div>
            </div>
        </div>
    }
</div>

<table class="table table-bordered table-stripped table-hover">
    @foreach (var advertisement in Model)
    {
        <tr style="cursor:pointer;height:100px;" >
            <td style="width:100px;">
                @if (advertisement.Pictures != null && advertisement.Pictures.Any())
                {
                    <img class="h-100 img-thumbnail" 
                         src="data:image;base64,@System.Convert.ToBase64String(advertisement.Pictures.Single(x=>x.IsMainPicture).Image)" />
                }
            </td>
            <td>
                <div class="h-100 d-flex flex-column justify-content-between">
                    <div>
                        <h5>@advertisement.Title</h5>
                    </div>
                    <div class="d-flex justify-content-between">
                        <div><strong>@advertisement.Location</strong> - @advertisement.DateOfPublication.ToString("f")</div>
                        <div class="table-nickname-caption d-flex align-items-end">Dodane przez: @advertisement.User?.Nickname</div>
                    </div>
                </div>
            </td>
            <td class="fit">
                <div class="fs-6 h-100 d-flex flex-column justify-content-start">
                    <strong>@advertisement.Price.ToString("0.00") zł</strong>
                </div>                
            </td>
        </tr>
    }

</table>
